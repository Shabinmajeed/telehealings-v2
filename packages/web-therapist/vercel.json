{
  "$schema": "https://vercel.com/docs/project-configuration",
  "buildCommand": "cd packages/web-therapist && npx tsc --noEmit && npx vite build",
  "outputDirectory": "packages/web-therapist/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
